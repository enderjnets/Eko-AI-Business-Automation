# ============================================
# Eko AI Business Automation — Environment Variables
# ============================================
# WARNING: This file is a TEMPLATE. Copy to .env and fill in ALL values.
# NEVER commit .env to git. Defaults marked [DEV ONLY] are insecure for production.

# Database
# WARNING: POSTGRES_PASSWORD must be changed in production. No default is safe.
POSTGRES_USER=eko
POSTGRES_PASSWORD=change_this_to_a_strong_password_in_production
POSTGRES_DB=eko_ai
DATABASE_URL=postgresql+asyncpg://eko:change_this_to_a_strong_password_in_production@localhost:5432/eko_ai

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=change_me_in_production

# API Keys
OPENAI_API_KEY=sk-...
RESEND_API_KEY=re_...
OUTSCRAPER_API_KEY=...
APIFY_API_KEY=...
YELP_API_KEY=...
SERPAPI_API_KEY=...

# Voice / TTS
ELEVENLABS_API_KEY=...
RETELL_API_KEY=...
VAPI_API_KEY=...
VAPI_PHONE_NUMBER_ID=...
VAPI_INBOUND_PHONE_NUMBER=+1-555-0000
VAPI_EKO_ASSISTANT_ID=...
VAPI_BLACK_VOLT_ASSISTANT_ID=...

# Calendar
CAL_COM_API_KEY=...
CAL_COM_USERNAME=...
GOOGLE_MEET_LINK=https://meet.google.com/...

# Inbound Email (Resend)
RESEND_WEBHOOK_SECRET=whsec_...
RESEND_INBOUND_DOMAIN=biz.ekoaiautomation.com
AUTO_CREATE_LEAD_FROM_INBOUND=true
AUTO_REPLY_ENABLED=true

# Security
# WARNING: SECRET_KEY must be at least 32 random chars in production.
# Generate with: openssl rand -hex 32
SECRET_KEY=generate_a_random_256_bit_key_here_min_32_chars

# App Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3001

# Compliance
DNC_SYNC_CRON=0 2 1 'archived' =0.1.9,' pyproject.toml && cat requirements.txt | tail -3 440 anthropic-quickstarts Application Support Applications auto_token.sh BitTrader bittrader-animator-draft bittrader-modal-deploy bittrader-remotion BittraderBot Analisis de Backtest BittraderBot_Installer_Package BittraderBot_Results BittraderBot_v17_OPTIMIZED_FIXED.mq5 BittraderBot_v17_TURBO.mq5 browser_automation_helper.sh BROWSER_USE_MCP_SETUP.md cAlgo claw-gpt claw-local claw-opus claw-profiles.env claw-profiles.env.example claw-sonnet claw-unsafe codex-vs-claude-code.html codex-vs-claude-code.pdf codex-vs-claude-code.txt codex-vs-claude-interactive.html coinbase_trader_venv Coinbase-Cripto-Trader-Claude ComfyUI comfyui_restart.log comfyui_server_error.log comfyui_server.log connect-eko.sh coordinator.db crypto_worker cTrader data_coingecko_free Desktop Documents Downloads eko_margie_sim.py eko_sim_script.py Eko-AI-Bussinnes-Automation eko-tunnel.sh ekobit-final-update.ps1 ekobit-minimax-m21.ps1 ekobit-minimax-update-v2.ps1 ekobit-minimax-update.ps1 ekobit-update-final.ps1 ekobit-update.ps1 execute_fix.sh fix_dashboard_js.php fix_function.js fix_website.py gen_winners_simple.py get-pip.py GitHub Google Drive Library Macintosh HD:Users:enderj:Desktop:screenshot_20260210_095756.png Movies Music OpenClaw_Trading_Corp pdf-work Pictures PlayOnMac's virtual drives Projects Public run-native-claw.sh run-on-ekobit.sh run-safe-claw.sh sandbox scripts Simple_NAS100_Repo Solana-Cripto-Trader start_browser_mcp.sh start_comfyui_bg.sh start_comfyui.sh stop_browser_mcp.sh tmp_nginx_eko.conf tmp_patch_main.py tmp_pricing.tsx twenty-repo-explore vision-workflow worker_env Worker_Para_Tu_Amigo *


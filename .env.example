# ============================================
# Eko AI Business Automation — Environment Variables
# ============================================

# Database
POSTGRES_USER=eko
POSTGRES_PASSWORD=eko_dev_pass
POSTGRES_DB=eko_ai
DATABASE_URL=postgresql+asyncpg://eko:eko_dev_pass@localhost:5432/eko_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# API Keys
OPENAI_API_KEY=sk-...
RESEND_API_KEY=re_...
OUTSCRAPER_API_KEY=...
APIFY_API_KEY=...

# Voice (phase 3)
RETELL_API_KEY=...
VAPI_API_KEY=...

# Calendar (phase 2)
CAL_COM_API_KEY=...
GOOGLE_CALENDAR_CREDENTIALS=...

# App Settings
SECRET_KEY=change-this-in-production
ENVIRONMENT=development
LOG_LEVEL=INFO

# Compliance
DNC_SYNC_CRON="0 2 1 * *"
